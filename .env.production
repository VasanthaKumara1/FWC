# ============================================
# FWC HRMS - Production Environment Template
# ============================================
# Copy to .env.production and update values

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://fwc_user:secure_password_here@postgres:5432/fwc_hrms
DB_USER=fwc_user
DB_PASSWORD=secure_password_here
DB_NAME=fwc_hrms

# ============================================
# AUTHENTICATION
# ============================================
BETTER_AUTH_SECRET=generate-a-secure-secret-key-at-least-32-characters
BETTER_AUTH_URL=https://yourdomain.com
JWT_EXPIRY=86400000

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_ENV=production
NODE_ENV=production

# ============================================
# API KEYS
# ============================================
GEMINI_API_KEY=your-google-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# FRONTEND SERVICE
# ============================================
FRONTEND_URL=https://yourdomain.com

# ============================================
# BACKEND SERVICE
# ============================================
PORT=5000
API_BASE_URL=https://api.yourdomain.com

# ============================================
# ML SERVICES
# ============================================
ML_SERVICE_URL=http://ml-services:5001

# ============================================
# EMAIL SERVICE (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# AWS S3 (Optional - for file uploads)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=fwc-hrms-production

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-url

# ============================================
# SECURITY
# ============================================
SESSION_SECRET=another-secure-secret-key-32-chars-minimum
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
